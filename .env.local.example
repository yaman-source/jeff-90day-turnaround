# HubSpot Private App Token
# Get from: HubSpot → Settings → Integrations → Private Apps → Create private app
# Required scopes: crm.objects.contacts.write, crm.objects.contacts.read
HUBSPOT_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Resend API Key (free at resend.com)
# Get from: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optional) Custom FROM address — requires verified domain in Resend
# RESEND_FROM=90 Day Turnaround <notifications@90dayturnaround.ca>

# (Optional) Override the notification recipient email
# NOTIFY_EMAIL=jeff@90dayturnaround.ca
